# Ignorar contenido de src/ pero trackear la carpeta
# Cada proyecto adentro es su propio repo de GitHub — sin conflictos
src/*
!src/.gitkeep

# Ignorar datos generados por contenedores de Docker
mysql/
logs/
*.log

# Ignorar configuraciones específicas de Docker
docker-compose.override.yml

# Ignorar archivos temporales del sistema operativo
.DS_Store
Thumbs.db

# Ignorar archivos de configuración de IDEs
.vscode/
.idea/

# Ignorar dependencias de Composer (si las instalas localmente)
vendor/

# Ignorar archivos de configuración de PHP
php.ini

# Ignorar archivo de variables de entorno
.env